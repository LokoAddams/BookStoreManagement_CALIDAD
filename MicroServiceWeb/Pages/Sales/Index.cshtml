@page
@using System.Collections.Generic
@using System.Text.Json
@model LibraryWeb.Pages.Sales.IndexModel
@{
    ViewData["Title"] = "Ventas";
    int startNumber = (Model.Page - 1) * Model.PageSize;
    var statusMap = new Dictionary<string, (string, string)>
    {
        ["COMPLETED"] = ("bg-success", "Completada"),
        ["PENDING"] = ("bg-warning text-dark", "Pendiente"),
        ["CANCELLED"] = ("bg-danger", "Cancelada"),
        ["REFUNDED"] = ("bg-info", "Reembolsada")
    };
    var statusMapJson = JsonSerializer.Serialize(statusMap.ToDictionary(
        kvp => kvp.Key,
        kvp => new { badge = kvp.Value.Item1, label = kvp.Value.Item2 }));
}

<div class="card shadow-custom">
    <div class="card-header card-header-blue d-flex align-items-center justify-content-between flex-wrap gap-2">
        <h5 class="mb-0 text-white"><i class="fas fa-cash-register me-2 text-white"></i>Ventas</h5>
        <div class="d-flex align-items-center gap-2">
            <form method="get" class="d-flex align-items-center gap-2">
                <label class="form-label mb-0 small text-white">Mostrar</label>
                <div class="dropdown">
                    <button class="btn btn-light btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false" style="min-width: 70px;">
                        @Model.PageSize
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end shadow-sm">
                        @foreach (var size in new[] { 10, 20, 50, 100 })
                        {
                            <li>
                                <button type="submit" name="pageSize" value="@size" class="dropdown-item @(Model.PageSize == size ? "active" : "")">
                                    @size registros
                                </button>
                            </li>
                        }
                    </ul>
                </div>
                <input type="hidden" name="pageNumber" value="1" />
            </form>
            @if (User.IsInRole("Admin") || User.IsInRole("Employee"))
            {
                <a asp-page="Create" class="btn btn-primary btn-sm"><i class="fas fa-plus me-1"></i>Registrar Venta</a>
            }
        </div>
    </div>
    <div class="card-body bg-white">
        <div class="table-responsive">
            <table class="table table-striped table-hover table-bordered align-middle">
                <thead>
                    <tr>
                        <th class="th-blue">N�</th>
                        <th class="th-blue">Fecha</th>
                        <th class="th-blue">Cliente</th>
                        <th class="th-blue">CI-Cliente</th>
                        <th class="th-blue">Vendedor</th>
                        <th class="th-blue text-end">Total</th>
                        <th class="th-blue text-center">Estado</th>
                        @* <th class="th-blue text-center">Acciones</th> *@
                    </tr>
                </thead>
                <tbody>
                    @{
                        int i = 0;
                    }
                    @foreach (var sale in Model.Sales)
                    {
                        <tr>
                            <td>@(startNumber + (++i))</td>
                            <td>@sale.SaleDate.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@sale.ClientName</td>
                            <td>@sale.ClientCi</td>
                            <td>@sale.UserName</td>
                            <td class="text-end fw-bold">Bs @sale.Total.ToString("N2")</td>
                            <td class="text-center">
                                @{
                                    var statusKey = sale.Status ?? string.Empty;

                                    if (!statusMap.TryGetValue(statusKey, out var statusInfo))
                                    {
                                        var label = string.IsNullOrWhiteSpace(statusKey) ? "-" : statusKey;
                                        statusInfo = ("bg-secondary", label);
                                    }
                                }
                                <span class="badge @statusInfo.Item1">@statusInfo.Item2</span>
                            </td>
                            @* <td class="text-center table-actions">
                                <button type="button" class="btn btn-info btn-sm btn-icon" data-bs-toggle="modal" data-bs-target="#saleDetailModal" data-sale-id="@sale.Id">
                                    <i class="fas fa-eye"></i> Ver
                                </button>
                                @if (sale.Status == "COMPLETED")
                                {
                                    <a href="@Model.ReportsApiUrl/api/reports/sale/@sale.Id/pdf" target="_blank" class="btn btn-secondary btn-sm btn-icon" title="Descargar PDF">
                                        <i class="fas fa-file-pdf"></i>
                                    </a>
                                }
                            </td> *@
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (!Model.Sales.Any())
        {
            <div class="alert alert-info mb-0">No hay ventas registradas.</div>
        }

        <!-- Paginaci�n -->
        @if (Model.TotalPages > 1)
        {
            <nav class="d-flex justify-content-between align-items-center mt-3">
                <div class="text-muted small">
                    P�gina @Model.Page de @Model.TotalPages
                </div>
                <ul class="pagination pagination-sm mb-0">
                    <li class="page-item @(Model.Page == 1 ? "disabled" : "")">
                        <a class="page-link rounded-start-pill" asp-page="Index" asp-route-pageNumber="1" asp-route-pageSize="@Model.PageSize" title="Primera">
                            <i class="fas fa-angles-left"></i>
                        </a>
                    </li>
                    <li class="page-item @(Model.Page == 1 ? "disabled" : "")">
                        <a class="page-link" asp-page="Index" asp-route-pageNumber="@(Model.Page - 1)" asp-route-pageSize="@Model.PageSize" title="Anterior">
                            <i class="fas fa-angle-left"></i>
                        </a>
                    </li>
                    @{
                        int start = Math.Max(1, Model.Page - 2);
                        int end = Math.Min(Model.TotalPages, Model.Page + 2);
                        if (start > 1)
                        {
                            <li class="page-item disabled"><span class="page-link">...</span></li>
                        }
                    }
                    @for (int p = start; p <= end; p++)
                    {
                        <li class="page-item @(p == Model.Page ? "active" : "")">
                            <a class="page-link" asp-page="Index" asp-route-pageNumber="@p" asp-route-pageSize="@Model.PageSize">@p</a>
                        </li>
                    }
                    @if (end < Model.TotalPages)
                    {
                        <li class="page-item disabled"><span class="page-link">...</span></li>
                    }
                    <li class="page-item @(Model.Page == Model.TotalPages ? "disabled" : "")">
                        <a class="page-link" asp-page="Index" asp-route-pageNumber="@(Model.Page + 1)" asp-route-pageSize="@Model.PageSize" title="Siguiente">
                            <i class="fas fa-angle-right"></i>
                        </a>
                    </li>
                    <li class="page-item @(Model.Page == Model.TotalPages ? "disabled" : "")">
                        <a class="page-link rounded-end-pill" asp-page="Index" asp-route-pageNumber="@Model.TotalPages" asp-route-pageSize="@Model.PageSize" title="�ltima">
                            <i class="fas fa-angles-right"></i>
                        </a>
                    </li>
                </ul>
            </nav>
        }
    </div>
</div>

<!-- Modal de Detalle de Venta -->
<div class="modal fade" id="saleDetailModal" tabindex="-1" aria-labelledby="saleDetailModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header card-header-blue">
                <h5 class="modal-title text-white" id="saleDetailModalLabel"><i class="fas fa-file-invoice me-2"></i>Detalle de Venta</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <div id="saleDetailContent"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var salesApiUrl = '@Model.SalesApiUrl';
        var reportsApiUrl = '@Model.ReportsApiUrl';
        const statusConfig = @Html.Raw(statusMapJson);
        const defaultStatus = { badge: 'bg-secondary', label: '-' };
        const getStatusBadge = (status) => {
            const config = status ? statusConfig[status] : null;
            const badge = config?.badge ?? defaultStatus.badge;
            const label = config?.label ?? (status || defaultStatus.label);
            return `<span class="badge ${badge}">${label}</span>`;
        };
        const loadingTemplate = `
            <div class="text-center py-4">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Cargando...</span>
                </div>
                <p class="mt-2 text-muted">Cargando detalles...</p>
            </div>
        `;
        
        const saleDetailModal = document.getElementById('saleDetailModal');
        saleDetailModal.addEventListener('show.bs.modal', function (event) {
            const button = event.relatedTarget;
            const saleId = button.getAttribute('data-sale-id');
            const contentDiv = document.getElementById('saleDetailContent');
            
            // Mostrar spinner
            contentDiv.innerHTML = loadingTemplate;
            
            // Cargar detalles de la venta
            fetch(salesApiUrl + '/api/sales/' + saleId)
                .then(response => response.json())
                .then(sale => {
                    const statusBadge = getStatusBadge(sale.status);
                    
                    var detailsHtml = `
                        <div class="row mb-4">
                            <div class="col-md-6">
                                <p class="mb-1"><strong>Fecha:</strong> ${new Date(sale.saleDate).toLocaleString('es-BO')}</p>
                                <p class="mb-1"><strong>Cliente:</strong> ${sale.clientName || '-'}</p>
                                <p class="mb-1"><strong>CI/NIT:</strong> ${sale.clientCi || '-'}</p>
                            </div>
                            <div class="col-md-6">
                                <p class="mb-1"><strong>Vendedor:</strong> ${sale.userName || '-'}</p>
                                <p class="mb-1"><strong>Estado:</strong> ${statusBadge}</p>
                            </div>
                        </div>
                        <h6 class="fw-bold mb-3"><i class="fas fa-list me-2"></i>Productos</h6>
                        <div class="table-responsive">
                            <table class="table table-sm table-bordered">
                                <thead class="table-light">
                                    <tr>
                                        <th>Producto</th>
                                        <th class="text-center" style="width: 80px;">Cant.</th>
                                        <th class="text-end" style="width: 120px;">P. Unit.</th>
                                        <th class="text-end" style="width: 120px;">Subtotal</th>
                                    </tr>
                                </thead>
                                <tbody>
                    `;
                    
                    if (sale.details && sale.details.length > 0) {
                        sale.details.forEach(function(detail) {
                            detailsHtml += `
                                <tr>
                                    <td>${detail.productName || '-'}</td>
                                    <td class="text-center">${detail.quantity}</td>
                                    <td class="text-end">Bs ${detail.unitPrice.toFixed(2)}</td>
                                    <td class="text-end">Bs ${detail.subtotal.toFixed(2)}</td>
                                </tr>
                            `;
                        });
                    } else {
                        detailsHtml += '<tr><td colspan="4" class="text-center text-muted">Sin productos</td></tr>';
                    }
                    
                    detailsHtml += `
                                </tbody>
                                <tfoot>
                                    <tr class="table-light">
                                        <td colspan="3" class="text-end fw-bold">Total:</td>
                                        <td class="text-end fw-bold text-primary">Bs ${sale.total.toFixed(2)}</td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    `;
                    
                    if (sale.status === 'COMPLETED') {
                        detailsHtml += `
                            <div class="mt-3 text-end">
                                <a href="${reportsApiUrl}/api/reports/sale/${sale.id}/pdf" target="_blank" class="btn btn-outline-primary">
                                    <i class="fas fa-file-pdf me-1"></i>Descargar PDF
                                </a>
                            </div>
                        `;
                    }
                    
                    contentDiv.innerHTML = detailsHtml;
                })
                .catch(function(error) {
                    contentDiv.innerHTML = `
                        <div class="alert alert-danger">
                            <i class="fas fa-exclamation-triangle me-2"></i>Error al cargar los detalles de la venta.
                        </div>
                    `;
                    console.error('Error:', error);
                });
        });
    </script>
}
